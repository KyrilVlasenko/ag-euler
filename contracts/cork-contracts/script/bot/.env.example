# Cork Protected Loop Liquidation Bot
# Copy to .env and fill in values before running setup.sh or run.sh

# ── RPC ──────────────────────────────────────────────────────────────────────
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Bot wallet ───────────────────────────────────────────────────────────────
# The EOA that sends liquidation transactions. Must hold ETH for gas.
# Profits (excess sUSDe, leftover cST/vbUSDC) accumulate in this wallet.
BOT_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY

# ── Euler infrastructure ─────────────────────────────────────────────────────
EVC=0x0C9a3dd6b8F28529d72d7f9cE918D493519EE383

# ── Cork deployment addresses ────────────────────────────────────────────────
SUSDE_VAULT=0x53FDab35Fd3aA26577bAc29f098084fCBAbE502f
VBUSDC_VAULT=0xadF7aFDAdaA4cBb0aDAf47C7fD7a9789C0128C6b
CST_VAULT=0xd0f8aC1782d5B80f722bd6aCA4dEf8571A9ddA4c
CORK_LIQUIDATOR=0x36850466928a9B9c500b008EebC0221A105ba46e
SUSDE_TOKEN=0x9D39A5DE30e57443BfF2A8307A4256c8797A3497

# ── Polling ──────────────────────────────────────────────────────────────────
# Seconds between health checks (default: 30)
POLL_INTERVAL=30

# Block from which to scan for Borrow events to discover borrowers.
# Set to the block the sUSDe vault was deployed.
SCAN_FROM_BLOCK=21000000

# ── Alerts (optional) ────────────────────────────────────────────────────────
# Webhook URL for notifications (Discord, Slack, etc). Leave empty to skip.
WEBHOOK_URL=
